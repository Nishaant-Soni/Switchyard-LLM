# --- Provider keys ---------------------------------------------------------
# Groq is enough to run everything; the others are optional. A provider whose
# key is unset is skipped at startup (the gateway still runs on the rest).
GROQ_API_KEY=gsk_your_key_here          # https://console.groq.com/keys
GEMINI_API_KEY=                         # enables the `smart` alias primary
OPENROUTER_API_KEY=                     # enables the `cheap` alias primary

# --- Optional overrides (defaults shown) -----------------------------------
# REQUEST_TIMEOUT_S=60

# Ollama base URL. Local default is localhost; docker-compose sets the service URL.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Rate limiting — only active when config/tenants.yaml defines tenants (needs Redis).
# REDIS_URL=redis://localhost:6379/0     # docker-compose sets redis://redis:6379/0
# RATE_LIMIT_WINDOW_S=60

# Semantic cache.
# CACHE_ENABLED=true                     # set false for routing-only (no MiniLM download)
# CACHE_SIMILARITY_THRESHOLD=0.90        # tuned via the benchmark sweep
# CACHE_TTL_S=3600
# CACHE_MAX_ENTRIES=10000
# CACHE_PER_TENANT=false
