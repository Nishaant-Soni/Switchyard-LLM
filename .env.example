# Groq free-tier API key — get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Optional — enable the `smart` / `cheap` aliases' primary targets.
# Providers with an unset key are skipped at startup (the gateway still runs).
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides (defaults shown)
# REQUEST_TIMEOUT_S=60
# Rate limiting (Phase 3) — only used when config/tenants.yaml has tenants.
# REDIS_URL=redis://localhost:6379/0   # docker-compose sets redis://redis:6379/0
# RATE_LIMIT_WINDOW_S=60
