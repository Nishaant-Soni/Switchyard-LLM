{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["switchyard", "llm-gateway"],
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "Switchyard LLM Gateway",
  "uid": "switchyard-gateway",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency p95 by provider (s)",
      "description": "histogram_quantile p95 of upstream latency (time-to-first-byte for streams).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(switchyard_request_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by provider / outcome (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(switchyard_requests_total[1m])) by (provider, outcome)",
          "legendFormat": "{{provider}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache hit rate",
      "description": "hits / (hits + misses); streaming bypasses are excluded.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(switchyard_cache_events_total{event=\"hit\"}[5m])) / sum(rate(switchyard_cache_events_total{event=~\"hit|miss\"}[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token throughput by provider / direction (tok/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(switchyard_tokens_total[1m])) by (provider, direction)",
          "legendFormat": "{{provider}} / {{direction}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Counterfactual cost by tenant ($ / 5m)",
      "description": "usage x config/pricing.yaml list prices — what this traffic would cost on paid tiers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(switchyard_cost_usd_total[5m])) by (tenant)",
          "legendFormat": "{{tenant}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors by type (err/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(switchyard_errors_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ]
}
